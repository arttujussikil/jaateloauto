# VR Data Platform — ympäristömuuttujat
# Kopioi tämä tiedosto nimellä .env ja muokkaa tarvittaessa.

# Digitraffic edellyttää Digitraffic-User -otsikkoa 1.12.2024 alkaen.
# Muodon suositus: sovelluksen_nimi/versio yhteysosoite
DIGITRAFFIC_USER=vr-data-platform/0.1 opiskelija@example.com

# Staging-kansio (oletus: projektin juuri/02_staging)
STAGING_DIR=02_staging/data

# Bronze-kansio
BRONZE_DIR=03_bronze/data

# DuckDB-tietokantatiedosto (silver + gold)
DUCKDB_PATH=04_silver/vr_warehouse.duckdb

# Staging TTL päivinä (vanhemmat tiedostot poistetaan automaattisesti)
STAGING_TTL_DAYS=14

# Kuinka monta päivää historiaa haetaan kerralla
FETCH_DAYS_BACK=7
